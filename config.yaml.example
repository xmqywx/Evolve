agent:
  name: "Evolve"
  data_dir: "/path/to/Evolve"
  db_path: "/path/to/Evolve/agent.db"
  persona_dir: "/path/to/Evolve/persona"

claude:
  binary: "claude"
  default_cwd: "/path/to/workspace"
  timeout: 600
  args:
    - "--dangerously-skip-permissions"
    - "--output-format"
    - "stream-json"

scheduler:
  max_daily_calls: 50
  min_interval_seconds: 30

server:
  host: "0.0.0.0"
  port: 3818
  secret: "change-me"

feishu:
  app_id: ""
  app_secret: ""
  bot_webhook: ""
  chat_id: ""
  enabled: false

relay:
  url: ""
  token: ""
  reconnect_interval: 5
  enabled: false

doubao:
  api_key: ""
  base_url: "https://ark.cn-beijing.volces.com/api/v3"
  chat_model: "doubao-seed-2-0-pro-260215"
  embedding_model: "doubao-embedding-large-text-240915"
  enabled: true

postgres:
  dsn: "postgresql://user@localhost/evolve"
  enabled: false

scanner:
  process_interval: 5
  claude_projects_dir: "~/.claude/projects"
  max_messages_cached: 200

jwt:
  secret: "change-me-jwt-secret"
  expiry_hours: 168

survival:
  enabled: true
  workspace: "/path/to/workspace"

digital_humans:
  executor:
    persona_dir: persona/executor
    cmux_session: mycmux-executor
    provider: codex
    heartbeat_interval_secs: 600
    skill_whitelist: ["*"]
    endpoint_allowlist: ["heartbeat", "deliverable", "discovery", "workflow", "upgrade", "review"]
    enabled: true
  observer:
    persona_dir: persona/observer
    cmux_session: mycmux-observer
    provider: codex
    heartbeat_interval_secs: 1800
    skill_whitelist: []
    endpoint_allowlist: ["heartbeat", "discovery"]
    enabled: false  # set true when Observer runtime (S1 Task 9) is wired
